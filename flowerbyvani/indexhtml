<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vaniflower - All in JS</title>
</head>
<body>
    <div id="app"></div>

    <script>
        // 1. CSS dalam JavaScript
        const style = document.createElement('style');
        style.textContent = `
            body { 
                font-family: sans-serif; 
                background: #f0fdf4; 
                display: flex; 
                justify-content: center; 
                align-items: center; 
                height: 100vh; 
                margin: 0; 
            }
            .card { 
                background: white; 
                padding: 30px; 
                border-radius: 20px; 
                box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
                text-align: center; 
                width: 300px;
            }
            .moisture-val { font-size: 3rem; color: #2563eb; font-weight: bold; }
            .btn-siram { 
                background: #22c55e; 
                color: white; 
                border: none; 
                padding: 12px 25px; 
                border-radius: 10px; 
                cursor: pointer; 
                font-size: 1rem;
                margin-top: 20px;
            }
            .btn-siram:disabled { background: #94a3b8; }
            #plant { font-size: 80px; transition: 0.5s; }
        `;
        document.head.appendChild(style);

        // 2. Membuat Struktur Elemen
        const app = document.getElementById('app');
        const card = document.createElement('div');
        card.className = 'card';

        card.innerHTML = `
            <h1 style="color: #166534; margin-bottom: 0;">Vaniflower</h1>
            <p style="color: #666; margin-top: 5px;">Smart Garden System</p>
            <div class="moisture-val" id="lvl">45%</div>
            <p>Kelembapan Tanah</p>
            <div id="plant">🌵</div>
            <button class="btn-siram" id="btn">Siram Tanaman</button>
        `;

        app.appendChild(card);

        // 3. Logika Interaksi
        const btn = document.getElementById('btn');
        const lvl = document.getElementById('lvl');
        const plant = document.getElementById('plant');

        btn.onclick = () => {
            btn.disabled = true;
            btn.innerText = "Menyiram...";
            plant.innerText = "💧";
            
            // Simulasi proses menyiram
            setTimeout(() => {
                lvl.innerText = "90%";
                plant.innerText = "🌻";
                btn.innerText = "Sudah Segar!";
                
                setTimeout(() => {
                    btn.disabled = false;
                    btn.innerText = "Siram Lagi";
                }, 2000);
            }, 1500);
        };
    </script>
</body>
</html>
